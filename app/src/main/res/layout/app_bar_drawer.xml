<?xml version="1.0" encoding="utf-8"?>
<!--
  ColorOS 16 渐变 AppBar。
  关键：MaterialToolbar / AppBarLayout 在本机 (ColorOS) 上会用 colorSurface 强制覆盖
  drawable 背景，导致渐变 drawable 不渲染。解决办法是把渐变放在一个普通 View 上
  （普通 View 的 drawable 一定会渲染），再让 MaterialToolbar 背景透明叠在其上。
-->
<com.google.android.material.appbar.AppBarLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/toolbar_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:animateLayoutChanges="true"
    android:background="@android:color/transparent"
    android:elevation="0dp"
    app:elevation="0dp"
    app:statusBarForeground="@null"
    app:liftOnScroll="false">

    <!--
      不再用 fitsSystemWindows 把内容整体下推（那样渐变到不了状态栏，露出窗口背景出现接缝）。
      改为：渐变 View 铺满整个 FrameLayout（含状态栏区域），仅给工具栏内容
      (toolbar_content) 顶部加状态栏高度的 padding，由各 Activity 的 insets 监听器设置。
    -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 渐变背景层（普通 View，drawable 一定渲染），铺满含状态栏 -->
        <View
            android:id="@+id/toolbar_gradient"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_appbar" />

        <LinearLayout
            android:id="@+id/toolbar_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@android:color/transparent"
                app:titleTextColor="@android:color/white" />

            <!-- 首页搜索框（默认隐藏，仅 MainActivity 显示）匹配设计稿 .search-box -->
            <LinearLayout
                android:id="@+id/toolbar_search_box"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="14dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_search_pill"
                android:visibility="gone">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="8dp"
                    android:alpha="0.85"
                    app:srcCompat="@drawable/ic_search_white_24dp" />

                <EditText
                    android:id="@+id/toolbar_search_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="@string/main_search_hint"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#99FFFFFF"
                    android:textSize="14sp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:maxLines="1"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:importantForAutofill="no" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</com.google.android.material.appbar.AppBarLayout>

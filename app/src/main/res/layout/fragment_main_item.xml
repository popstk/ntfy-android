<?xml version="1.0" encoding="utf-8"?>
<!-- ColorOS 16 风格频道卡片：白色大圆角卡片，灰色背景上浮起 -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <!-- 内层不再 clickable，避免拦截卡片点击导致话题点不进去 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <!-- 圆角方形图标容器 -->
        <FrameLayout
            android:id="@+id/main_item_icon_container"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_channel_blue"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/main_item_image"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:visibility="gone"
                app:srcCompat="@drawable/ic_sms_gray_24dp"/>

            <!-- 字母头像 (无自定义图标时显示) -->
            <TextView
                android:id="@+id/main_item_letter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="20sp"
                android:textStyle="bold"
                android:includeFontPadding="false"
                android:textColor="?attr/colorOnPrimaryContainer"/>

        </FrameLayout>

        <!-- 频道名 -->
        <TextView
            android:id="@+id/main_item_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:textSize="15sp"
            app:layout_constraintBottom_toTopOf="@id/main_item_status"
            app:layout_constraintEnd_toStartOf="@id/main_item_connection_error_image"
            app:layout_constraintStart_toEndOf="@id/main_item_icon_container"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"/>

        <!-- 状态文字 -->
        <TextView
            android:id="@+id/main_item_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/main_item_new"
            app:layout_constraintStart_toStartOf="@id/main_item_text"
            app:layout_constraintTop_toBottomOf="@id/main_item_text"/>

        <!-- 连接错误图标 -->
        <ImageView
            android:id="@+id/main_item_connection_error_image"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="3dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/main_item_text"
            app:layout_constraintEnd_toStartOf="@id/main_item_notification_disabled_until_image"
            app:layout_constraintTop_toTopOf="@id/main_item_text"
            app:srcCompat="@drawable/ic_warning_amber_24dp"/>

        <!-- 临时静音图标 -->
        <ImageView
            android:id="@+id/main_item_notification_disabled_until_image"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="3dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/main_item_text"
            app:layout_constraintEnd_toStartOf="@id/main_item_notification_disabled_forever_image"
            app:layout_constraintTop_toTopOf="@id/main_item_text"
            app:srcCompat="@drawable/ic_notifications_off_time_gray_outline_24dp"/>

        <!-- 永久静音图标 -->
        <ImageView
            android:id="@+id/main_item_notification_disabled_forever_image"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="3dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/main_item_text"
            app:layout_constraintEnd_toStartOf="@id/main_item_instant_image"
            app:layout_constraintTop_toTopOf="@id/main_item_text"
            app:srcCompat="@drawable/ic_notifications_off_gray_outline_24dp"/>

        <!-- 即时推送图标 -->
        <ImageView
            android:id="@+id/main_item_instant_image"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/main_item_text"
            app:layout_constraintEnd_toStartOf="@id/main_item_date"
            app:layout_constraintTop_toTopOf="@id/main_item_text"
            app:srcCompat="@drawable/ic_bolt_gray_24dp"/>

        <!-- 时间 -->
        <TextView
            android:id="@+id/main_item_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintBottom_toBottomOf="@id/main_item_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/main_item_text"/>

        <!-- 未读徽章（渐变胶囊） -->
        <TextView
            android:id="@+id/main_item_new"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:layout_marginTop="3dp"
            android:background="@drawable/bg_badge_gradient"
            android:gravity="center"
            android:minWidth="20dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/main_item_status"
            app:layout_constraintTop_toBottomOf="@id/main_item_date"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>

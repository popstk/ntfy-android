<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#AB47BC"
                android:endColor="#6A1B9A"
                android:angle="135"
                android:type="linear"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
    <item
        android:top="5dp" android:bottom="5dp"
        android:left="5dp" android:right="5dp"
        android:drawable="@drawable/ic_notification_instant"
        android:tint="#FFFFFF"/>
</layer-list>

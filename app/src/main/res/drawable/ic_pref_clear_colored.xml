<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#EF5350"
                android:endColor="#E53935"
                android:angle="135"
                android:type="linear"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
    <item
        android:top="7dp" android:bottom="7dp"
        android:left="7dp" android:right="7dp"
        android:drawable="@drawable/ic_pref_delete_white"
        android:tint="#FFFFFF"/>
</layer-list>
